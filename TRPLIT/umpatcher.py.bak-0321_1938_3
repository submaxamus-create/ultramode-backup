def create_display():
    info = pygame.display.Info()
    desktop_w = max(info.current_w, LOGICAL_WIDTH)
    desktop_h = max(info.current_h, LOGICAL_HEIGHT)
    attempts = [
        ((LOGICAL_WIDTH, LOGICAL_HEIGHT), pygame.SCALED | pygame.FULLSCREEN, "scaled fullscreen"),
        ((desktop_w, desktop_h), pygame.SCALED, "desktop scaled"),
        ((desktop_w, desktop_h), pygame.FULLSCREEN, "fullscreen"),
        ((LOGICAL_WIDTH, LOGICAL_HEIGHT), 0, "windowed fallback"),
    ]
    for size, flags, label in attempts:
        try:
            screen = pygame.display.set_mode(size, flags)
            return screen, label, desktop_w, desktop_h
        except pygame.error:
            continue
    screen = pygame.display.set_mode((LOGICAL_WIDTH, LOGICAL_HEIGHT))
    return screen, "windowed fallback", desktop_w, desktop_h


  def run_restore_browser(screen, font, small, tiny):
      # Quick, simple backup browser
      running_browser = True
      clock = pygame.time.Clock()
      
      backup_dirs = [
          Path("/userdata/system/ultramode/backups/self"),
          Path("/userdata/system/ultramode/backups/undo")
      ]
      
      files = []
      for d in backup_dirs:
          if d.exists():
              for f in d.iterdir():
                  if f.is_file():
                      files.append(f)
                      
      files.sort(key=lambda x: x.stat().st_mtime, reverse=True)
      selected = 0
      scroll_offset = 0
      max_visible = 10
      ticks = 0
      
      joy = None
      if pygame.joystick.get_count() > 0:
          joy = pygame.joystick.Joystick(0)
          joy.init()
          
      def draw_browser():
          screen.fill((5, 5, 15))
          
          # Title
          pulse = int(200 + 55 * math.sin(ticks * 0.1))
          t_surf = font.render("RESTORE BACKUP BROWSER", True, (pulse, 150, 255))
          screen.blit(t_surf, (screen.get_width()//2 - t_surf.get_width()//2, 30))
          
          if not files:
              msg = small.render("No backups found in /backups/self or /backups/undo", True, (255, 100, 100))
              screen.blit(msg, (screen.get_width()//2 - msg.get_width()//2, 100))
              return
              
          y = 100
          for i in range(scroll_offset, min(len(files), scroll_offset + max_visible)):
              fpath = files[i]
              if i == selected:
                  r = int(50)
                  g = int(200 + 55 * math.sin(ticks * 0.2))
                  b = int(200 + 55 * math.sin(ticks * 0.2))
                  c = (r, g, b)
                  prefix = "► "
              else:
                  c = (150, 150, 150)
                  prefix = "   "
                  
              mtime = time.strftime("%Y-%m-%d %H:%M:%S", time.localtime(fpath.stat().st_mtime))
              text = f"{prefix}{mtime} | {fpath.parent.name} | {fpath.name}"
              
              # Truncate
              if len(text) > 80:
                  text = text[:77] + "..."
                  
              surf = small.render(text, True, c)
              screen.blit(surf, (50, y))
              y += 40
              
          help_surf = tiny.render("UP/DOWN: Move  |  ENTER/A: Restore  |  ESC/B: Back", True, (200, 200, 255))
          screen.blit(help_surf, (50, screen.get_height() - 40))

      while running_browser:
          ticks += 1
          draw_browser()
          pygame.display.flip()
          
          for event in pygame.event.get():
              if event.type == pygame.QUIT:
                  return "Aborted"
              if event.type == pygame.KEYDOWN:
                  if event.key == pygame.K_ESCAPE:
                      return "Cancelled restore."
                  elif event.key == pygame.K_UP:
                      if files:
                          selected = (selected - 1) % len(files)
                          if selected < scroll_offset: scroll_offset = selected
                          elif selected >= scroll_offset + max_visible: scroll_offset = selected - max_visible + 1
                  elif event.key == pygame.K_DOWN:
                      if files:
                          selected = (selected + 1) % len(files)
                          if selected >= scroll_offset + max_visible: scroll_offset = selected - max_visible + 1
                          elif selected < scroll_offset: scroll_offset = selected
                  elif event.key in (pygame.K_RETURN, pygame.K_KP_ENTER):
                      if files:
                          target = files[selected]
                          # Super simple restore: if it's umpatcher, overwrite umpatcher. Otherwise overwrite original path.
                          # For undo, we'd need the log. For self, we know it's umpatcher.
                          try:
                              if "self" in str(target):
                                  dest = Path("/userdata/system/ultramode/umpatcher.py")
                              else:
                                  # Best effort guess for undo without parsing the log
                                  orig_name = target.name.split("_", 1)[-1]
                                  # We assume it came from ultramode dir
                                  dest = Path("/userdata/system/ultramode") / orig_name
                              
                              shutil.copy2(target, dest)
                              return f"Restored {target.name} to {dest}"
                          except Exception as e:
                              return f"Restore failed: {e}"
              elif joy and event.type == pygame.JOYHATMOTION:
                  hat = joy.get_hat(0)
                  if hat[1] == 1 and files:
                      selected = (selected - 1) % len(files)
                      if selected < scroll_offset: scroll_offset = selected
                      elif selected >= scroll_offset + max_visible: scroll_offset = selected - max_visible + 1
                  elif hat[1] == -1 and files:
                      selected = (selected + 1) % len(files)
                      if selected >= scroll_offset + max_visible: scroll_offset = selected - max_visible + 1
                      elif selected < scroll_offset: scroll_offset = selected
              elif joy and event.type == pygame.JOYBUTTONDOWN:
                  if event.button == 0 and files:
                      target = files[selected]
                      try:
                          if "self" in str(target):
                              dest = Path("/userdata/system/ultramode/umpatcher.py")
                          else:
                              orig_name = target.name.split("_", 1)[-1]
                              dest = Path("/userdata/system/ultramode") / orig_name
                          shutil.copy2(target, dest)
                          return f"Restored {target.name} to {dest}"
                      except Exception as e:
                          return f"Restore failed: {e}"
                  elif event.button == 1:
                      return "Cancelled restore."
                      
          clock.tick(60)
      return "Done."
  

def grab_from_xclip():
    try:
        if shutil.which("xclip"):
            result = subprocess.run(
                ["xclip", "-o", "-selection", "clipboard"],
                capture_output=True,
                text=True,
                timeout=2,
            )
            if result.returncode == 0 and result.stdout and result.stdout.strip():
                return result.stdout, "xclip"
    except Exception:
        pass
    return "", ""


def grab_from_buffer_file():
    try:
        if os.path.exists(BUFFER_PATH):
            with open(BUFFER_PATH, "r", encoding="utf-8") as f:
                data = f.read()
            if data and data.strip():
                return data, "buffer.txt"
    except Exception:
        pass
    return "", ""


def grab_hidden_tk_clipboard():
    if not TK_AVAILABLE:
        return "", ""
    try:
        root = tk.Tk()
        root.withdraw()
        try:
            data = root.clipboard_get()
        except Exception:
            data = ""
        root.destroy()
        if data and data.strip():
            return data, "Tk clipboard"
    except Exception:
        pass
    return "", ""


def grab_from_pygame_scrap():
    try:
        import pygame.scrap as scrap
        if not scrap.get_init():
            scrap.init()
        raw = scrap.get(pygame.SCRAP_TEXT)
        if raw:
            return raw.decode("utf-8", errors="ignore"), "pygame.scrap"
    except Exception:
        pass
    return "", ""


def ultramode_grab_buffer():
    for getter in (grab_from_xclip, grab_from_buffer_file, grab_hidden_tk_clipboard, grab_from_pygame_scrap):
        data, source = getter()
        if data and data.strip():
            return data, source
    return "", ""


def split_header_and_body(text):
    lines = text.splitlines()
    body_start = 0
    saw_summary = False

    for i, line in enumerate(lines):
        s = line.strip()
        if "SUMMARY:" in s.upper():
            saw_summary = True
        if saw_summary and s == "":
            body_start = i + 1
            break

    if body_start == 0:
        saw_meta = False
        for i, line in enumerate(lines):
            s = line.strip()
            if any(key in s.upper() for key in ["FILENAME:", "FOLDER PATH:", "DESTINATION:", "PATCH TYPE:", "VERSION:"]):
                saw_meta = True
            if saw_meta and s == "":
                body_start = i + 1
                break

    body_lines = lines[body_start:] if body_start < len(lines) else []
    while body_lines and body_lines[0].strip() == "":
        body_lines = body_lines[1:]
    return lines, body_lines


def classify_buffer(text):
    header_lines, body_lines = split_header_and_body(text)
    filename = "unknown.py"
    folder_path = ULTRAMODE_ROOT
    destination = ""
    version = ""
    patch_type = "FULL"
    target_line = ""
    summary_lines = []

    capture_summary = False
    for line in header_lines[:80]:
        s = line.strip()
        upper = s.upper()

        if "FILENAME:" in upper:
            try:
                filename = s.split(":", 1)[1].strip()
            except Exception:
                pass
        elif "FOLDER PATH:" in upper:
            try:
                folder_path = s.split(":", 1)[1].strip()
            except Exception:
                pass
        elif "DESTINATION:" in upper:
            try:
                destination = s.split(":", 1)[1].strip()
            except Exception:
                pass
        elif "VERSION:" in upper:
            try:
                version = s.split(":", 1)[1].strip()
            except Exception:
                pass
        elif "PATCH TYPE:" in upper:
            try:
                patch_type = s.split(":", 1)[1].strip().upper()
            except Exception:
                pass
        elif "TARGET_LINE:" in upper:
            try:
                target_line = s.split(":", 1)[1].strip()
            except Exception:
                pass
        elif "SUMMARY:" in upper:
            capture_summary = True
            try:
                tail = s.split(":", 1)[1].strip()
                if tail:
                    summary_lines.append(tail)
            except Exception:
                pass
        elif capture_summary:
            if s.startswith("#") and ":" not in s:
                summary_lines.append(s.lstrip("#").strip())
            elif s == "":
                capture_summary = False

    file_path = destination if destination else os.path.join(folder_path, filename)
    lower_name = filename.lower()
    body_text = "\n".join(body_lines)
    header_text = "\n".join(header_lines)

    confidence = 45
    obj_type = "Unknown Artifact"
    safety = "Unknown"

    if lower_name.endswith(".py") or "#!/usr/bin/env python3" in body_text or "def " in body_text:
        obj_type, confidence, safety = "Python Module", 92, "Medium"
    elif lower_name.endswith(".sh") or "#!/bin/bash" in body_text or "#!/usr/bin/env bash" in body_text:
        obj_type, confidence, safety = "Shell Tool", 90, "Medium"
    elif lower_name.endswith(".log") or "PERMANENT RULES" in header_text.upper() or "CONVERSATION" in header_text.upper() or "AI IDEAS" in header_text.upper():
        obj_type, confidence, safety = "Log / Journal", 94, "Low"
    elif "CATEGORY:" in header_text and "TYPE:" in header_text and "EXPORT_TO:" in header_text:
        obj_type, confidence, safety = "Notation / Notes", 91, "Low"
    elif patch_type in ("APPEND", "INSERT_AFTER", "INSERT_BEFORE", "REPLACE", "CREATE", "FULL"):
        obj_type, confidence, safety = "Patch Package", 88, "Medium"
    elif lower_name.endswith((".json", ".cfg", ".ini", ".yaml", ".yml")):
        obj_type, confidence, safety = "Config / Data", 84, "Low"
    elif "MAIN MENU" in header_text.upper() or "PARENT MENU" in header_text.upper() or "launcher" in body_text.lower():
        obj_type, confidence, safety = "Launcher / Menu Hook", 76, "High"

    recommendations = []
    if obj_type in ("Python Module", "Shell Tool", "Patch Package", "Launcher / Menu Hook"):
        recommendations += ["Preview before apply", "Backup self + target"]
    if obj_type in ("Log / Journal", "Notation / Notes"):
        recommendations += ["Append, do not overwrite"]
    if target_line:
        recommendations += [f"Anchor target: {target_line}"]
    if any(marker in text for marker in PROTECTED_MARKERS):
        recommendations += ["Protected markers detected"]

    return {
        "filename": filename,
        "folder": folder_path,
        "file_path": file_path,
        "destination": destination,
        "version": version,
        "patch_type": patch_type,
        "target_line": target_line,
        "summary": " ".join(summary_lines).strip(),
        "object_type": obj_type,
        "confidence": confidence,
        "safety": safety,
        "header_lines": header_lines,
        "body_lines": body_lines,
        "lines": body_lines,
        "preview_lines": body_lines[:20],
        "size": len(text),
        "line_count": len(body_lines),
        "recommendations": recommendations,
    }


def validate_patch(info):
    patch_type = str(info.get("patch_type", "")).upper().strip()
    checks = [
        ("Header filename present", bool(info.get("filename"))),
        ("Destination path present", bool(info.get("file_path"))),
        ("Patch type recognized", patch_type in {"CREATE", "APPEND", "FULL", "INSERT_AFTER", "INSERT_BEFORE", "REPLACE"}),
        ("Patch body present", len(info.get("body_lines", [])) > 0),
    ]
    if patch_type in ("INSERT_AFTER", "INSERT_BEFORE", "REPLACE"):
        checks.append(("Target line present", bool(info.get("target_line"))))
    return all(ok for _, ok in checks), checks


def apply_patch(info, simulation=False):
    path = info["file_path"]
    lines = info["body_lines"]
    patch_type = str(info.get("patch_type", "FULL")).upper().strip()
    target_line = str(info.get("target_line", "")).strip()

    if not path:
        return False, "ERROR: No target path detected."

    if simulation:
        return True, f"SIMULATION ONLY: Would apply {patch_type} to {path}"

    if patch_type in ("FULL", "REPLACE") and os.path.exists(path):
        try:
            with open(path, "r", encoding="utf-8") as f:
                existing_text = f.read()
        except Exception:
            existing_text = ""
        if existing_text and any(marker in existing_text for marker in PROTECTED_MARKERS):
            return False, "ERROR: Protected markers detected in target. Use preview and safer patch type first."

    os.makedirs(os.path.dirname(path), exist_ok=True)
    backup_self()

    existing_lines = []
    backup = None

    if os.path.exists(path):
        backup = backup_path(path)
        try:
            with open(path, "r", encoding="utf-8") as f:
                existing_lines = f.read().splitlines()
        except Exception as e:
            return False, f"ERROR reading target file: {e}"

    def write_lines(out_lines):
        data = "\n".join(out_lines) + ("\n" if out_lines else "")
        ok, err = atomic_write(path, data)
        if not ok:
            return False, f"ERROR writing file: {err}"
        msg = f"{patch_type} completed -> {path}"
        if backup:
            msg += f" | Backup: {os.path.basename(backup)}"
        return True, msg

    if patch_type == "CREATE":
        if os.path.exists(path):
            return False, f"ERROR: CREATE refused, file already exists -> {path}"
        return write_lines(lines)

    if patch_type == "APPEND":
        return write_lines(existing_lines + lines)

    if patch_type == "FULL":
        return write_lines(lines)

    if patch_type in ("INSERT_AFTER", "INSERT_BEFORE", "REPLACE"):
        if not target_line:
            return False, f"ERROR: {patch_type} requires TARGET_LINE"

        match_index = -1
        for i, line in enumerate(existing_lines):
            if target_line in line:
                match_index = i
                break

        if match_index == -1:
            return False, f"ERROR: TARGET_LINE not found -> {target_line}"

        if patch_type == "INSERT_AFTER":
            return write_lines(existing_lines[:match_index + 1] + lines + existing_lines[match_index + 1:])

        if patch_type == "INSERT_BEFORE":
            return write_lines(existing_lines[:match_index] + lines + existing_lines[match_index:])

        if patch_type == "REPLACE":
            return write_lines(existing_lines[:match_index] + lines + existing_lines[match_index + 1:])

    return False, f"ERROR: Unsupported PATCH TYPE -> {patch_type}"


def draw_vertical_gradient(screen, top_color, bottom_color):
    for y in range(screen.get_height()):
        blend = y / max(1, screen.get_height() - 1)
        r = int(top_color[0] + (bottom_color[0] - top_color[0]) * blend)
        g = int(top_color[1] + (bottom_color[1] - top_color[1]) * blend)
        b = int(top_color[2] + (bottom_color[2] - top_color[2]) * blend)
        pygame.draw.line(screen, (r, g, b), (0, y), (screen.get_width(), y))


def fit_text(font, text, max_width):
    text = str(text)
    if font.size(text)[0] <= max_width:
        return text
    ellipsis = "..."
    while text and font.size(text + ellipsis)[0] > max_width:
        text = text[:-1]
    return (text + ellipsis) if text else ellipsis


def draw_label_value(screen, label_font, value_font, colors, x, y, label, value, width, value_color=None, label_color=None):
    label_color = label_color or colors["ORANGE"]
    value_color = value_color or colors["WHITE"]
    label_surface = label_font.render(label, True, label_color)
    screen.blit(label_surface, (x, y))
    value_x = x + label_surface.get_width() + 6
    value_width = max(20, width - (value_x - x))
    screen.blit(value_font.render(fit_text(value_font, value, value_width), True, value_color), (value_x, y))


def draw_grid_cell(screen, colors, rect, label, value, label_font, value_font, value_color=None, label_color=None, fill=None, border=None):
    label_color = label_color or colors["NEON_YELLOW"]
    value_color = value_color or colors["WHITE"]
    fill = fill or colors["PANEL_DARK"]
    border = border or colors["NEON_YELLOW_DIM"]
    pygame.draw.rect(screen, fill, rect, border_radius=10)
    pygame.draw.rect(screen, border, rect, 2, border_radius=10)
    x, y, w, h = rect
    label_surface = label_font.render(fit_text(label_font, label, max(20, w // 2 - 10)), True, label_color)
    label_x = x + 8
    value_x = label_x + label_surface.get_width() + 8
    value_w = max(20, (x + w - 8) - value_x)
    baseline_y = y + (h - value_font.get_height()) // 2
    screen.blit(label_surface, (label_x, baseline_y))
    screen.blit(value_font.render(fit_text(value_font, value, value_w), True, value_color), (value_x, baseline_y))


def draw_inline_bubble(screen, colors, rect, lead, body, font, lead_color=None, body_color=None, fill=None, border=None, radius=10, shadow=False):
    fill = fill or colors["PANEL_DARK"]
    border = border or colors["BORDER"]
    lead_color = lead_color or colors["NEON_GREEN"]
    body_color = body_color or colors["WHITE"]

def atomic_write(path, data):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    fd, tmp = tempfile.mkstemp(dir=os.path.dirname(path))
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            f.write(data)
            f.flush()
            os.fsync(f.fileno())
        os.replace(tmp, path)
        return True, ""
    except Exception as e:
        try:
            if os.path.exists(tmp):
                os.remove(tmp)
        except Exception:
            pass
        return False, str(e)


def backup_self():
    try:
        src = os.path.abspath(__file__)
        dst = os.path.join(SELF_BACKUP_DIR, f"umpatcher_backup_{timestamp()}.py")
        shutil.copy2(src, dst)
        return True, os.path.basename(dst)
    except Exception as e:
        return False, str(e)


def backup_path(src_path):
    if not os.path.exists(src_path):
        return None
    dst = f"{src_path}.bak-{timestamp()}"
    try:
        with open(src_path, "rb") as s, open(dst, "wb") as d:
            d.write(s.read())
        return dst
    except Exception:
        return None



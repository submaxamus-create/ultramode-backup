def get_compat_actions(events):
    """
    Last-resort compatibility path:
    - D-pad / hat
    - common A / B buttons
    - axis threshold for menu movement only if hat/buttons do not arrive
    This is only used to supplement the shared shim, not replace it.
    """
    actions = {
        "up": False,
        "down": False,
        "left": False,
        "right": False,
        "accept": False,
        "back": False,
    }

    for event in events:
        if event.type == pygame.KEYDOWN:
            if event.key in (pygame.K_UP, pygame.K_w):
                actions["up"] = True
            elif event.key in (pygame.K_DOWN, pygame.K_s):
                actions["down"] = True
            elif event.key in (pygame.K_LEFT, pygame.K_a):
                actions["left"] = True
            elif event.key in (pygame.K_RIGHT, pygame.K_d):
                actions["right"] = True
            elif event.key in (pygame.K_RETURN, pygame.K_KP_ENTER, pygame.K_SPACE):
                actions["accept"] = True
            elif event.key in (pygame.K_ESCAPE, pygame.K_BACKSPACE):
                actions["back"] = True

        elif event.type == pygame.JOYHATMOTION:
            if event.value[1] == 1:
                actions["up"] = True
            elif event.value[1] == -1:
                actions["down"] = True
            if event.value[0] == -1:
                actions["left"] = True
            elif event.value[0] == 1:
                actions["right"] = True

        elif event.type == pygame.JOYBUTTONDOWN:
            # Common south / east mapping
            if event.button in (0,):
                actions["accept"] = True
            elif event.button in (1, 6, 7):
                actions["back"] = True

        elif event.type == pygame.JOYAXISMOTION:
            # left stick vertical / horizontal threshold
            if event.axis == 1:
                if event.value <= -0.75:
                    actions["up"] = True
                elif event.value >= 0.75:
                    actions["down"] = True
            elif event.axis == 0:
                if event.value <= -0.75:
                    actions["left"] = True
                elif event.value >= 0.75:
                    actions["right"] = True

    return actions


def merged_actions(events):
    """
    Merge shared shim actions with compatibility fallback actions.
    """
    pad.update(events)
    compat = get_compat_actions(events)

    return {
        "up": bool(pad.up() or compat["up"]),
        "down": bool(pad.down() or compat["down"]),
        "left": bool(pad.left() or compat["left"]),
        "right": bool(pad.right() or compat["right"]),
        "accept": bool(pad.accept() or compat["accept"]),
        "back": bool(pad.back() or compat["back"]),
    }


def move_zone_down():
    global focus_zone, selected_pane
    if focus_zone == "toggles":
        focus_zone = "menu"
    elif focus_zone == "menu":
        focus_zone = "pane"
        selected_pane = min(selected_pane, len(build_xclip_actions()) - 1)


def move_zone_up():
    global focus_zone
    if focus_zone == "pane":
        focus_zone = "menu"
    elif focus_zone == "menu":
        focus_zone = "toggles"


def on_nav(now, fn):
    global last_nav_time
    if now - last_nav_time > INPUT_DELAY:
        fn()
        last_nav_time = now


def process_navigation(events):
    global running, selected_menu, selected_pane, selected_toggle, status_message, focus_zone

    actions = merged_actions(events)
    now = time.time()

    for event in events:
        if event.type == pygame.QUIT:
            running = False
        elif event.type == XCLIP_EVENT:
            ok = getattr(event, "ok", False)
            msg = getattr(event, "msg", "")
            status_message = f"xclip action complete: {msg}" if ok else f"xclip action failed: {msg}"
        elif event.type == pygame.KEYDOWN:
            if event.key == pygame.K_TAB:
                if focus_zone == "toggles":
                    focus_zone = "menu"
                elif focus_zone == "menu":
                    focus_zone = "pane"
                else:
                    focus_zone = "toggles"
            elif event.key == pygame.K_f:
                cycle_font_mode()
            elif event.key == pygame.K_d:
                toggle_dark_mode()
            elif event.key == pygame.K_v:
                toggle_dev_mode()

    if actions["up"]:
        def _up():
            global selected_menu, selected_pane, selected_toggle
            if focus_zone == "menu":
                if selected_menu == 0:
                    move_zone_up()
                else:
                    selected_menu = (selected_menu - 1) % len(MENU)
            elif focus_zone == "pane":
                if selected_pane == 0:
                    move_zone_up()
                else:
                    selected_pane = max(0, selected_pane - 1)
            else:
                selected_toggle = (selected_toggle - 1) % 3
        on_nav(now, _up)

    elif actions["down"]:
        def _down():
            global selected_menu, selected_pane, selected_toggle
            if focus_zone == "menu":
                if selected_menu == len(MENU) - 1:
                    move_zone_down()
                else:
                    selected_menu = (selected_menu + 1) % len(MENU)
            elif focus_zone == "pane":
                action_list = build_xclip_actions()
                if selected_pane >= len(action_list) - 1:
                    selected_pane = len(action_list) - 1
                else:
                    selected_pane += 1
            else:
                selected_toggle = (selected_toggle + 1) % 3
        on_nav(now, _down)

    elif actions["left"]:
        def _left():
            global focus_zone, selected_toggle
            if focus_zone == "pane":
                focus_zone = "menu"
            elif focus_zone == "menu":
                focus_zone = "toggles"
            elif focus_zone == "toggles":
                selected_toggle = (selected_toggle - 1) % 3
        on_nav(now, _left)

    elif actions["right"]:
        def _right():
            global focus_zone, selected_toggle
            if focus_zone == "toggles":
                selected_toggle = (selected_toggle + 1) % 3
            elif focus_zone == "menu":
                focus_zone = "pane"
            elif focus_zone == "pane":
                focus_zone = "menu"
        on_nav(now, _right)

    if actions["accept"]:
        if focus_zone == "menu":
            status_message = handle_menu_select(selected_menu)
        elif focus_zone == "pane":
            status_message = handle_pane_select(selected_pane)
        else:
            activate_toggle(selected_toggle)

    if actions["back"]:
        if focus_zone in ("pane", "toggles"):
            focus_zone = "menu"
        else:
            running = False


def main_loop():
    global running
    draw_screen()
    while running:
        try:
            events = pygame.event.get()
            process_navigation(events)
            draw_screen()
            clock.tick(30)
        except Exception as exc:
            logger.exception("main loop crash prevented: %s", exc)
            time.sleep(0.05)


if __name__ == "__main__":
    try:
        main_loop()
    finally:
        pygame.quit()
        sys.exit()


    class UMGamepad:
        def __init__(self):
            self._pressed = set()

        def update(self, events=None):
            self._pressed.clear()
            if not events:
                return
            for event in events:
                if event.type == pygame.KEYDOWN:
                    self._pressed.add(event.key)

        def up(self):
            return pygame.K_UP in self._pressed or pygame.K_w in self._pressed

        def down(self):
            return pygame.K_DOWN in self._pressed or pygame.K_s in self._pressed

        def left(self):
            return pygame.K_LEFT in self._pressed or pygame.K_a in self._pressed

        def right(self):
            return pygame.K_RIGHT in self._pressed or pygame.K_d in self._pressed

        def accept(self):
            return pygame.K_RETURN in self._pressed or pygame.K_KP_ENTER in self._pressed

        def back(self):
            return pygame.K_ESCAPE in self._pressed or pygame.K_BACKSPACE in self._pressed

        def mouse_delta(self):
            return (0, 0)

        def mouse_left(self):
            return False

        def mouse_right(self):
            return False


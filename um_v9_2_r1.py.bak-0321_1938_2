def draw_vertical_gradient(surface, top_color, bottom_color):
    for y in range(surface.get_height()):
        blend = y / max(1, surface.get_height() - 1)
        r = int(top_color[0] + (bottom_color[0] - top_color[0]) * blend)
        g = int(top_color[1] + (bottom_color[1] - top_color[1]) * blend)
        b = int(top_color[2] + (bottom_color[2] - top_color[2]) * blend)
        pygame.draw.line(surface, (r, g, b), (0, y), (surface.get_width(), y))


def fit_text(font, text, max_width):
    text = str(text)
    if font.size(text)[0] <= max_width:
        return text
    ellipsis = '...'
    while text and font.size(text + ellipsis)[0] > max_width:
        text = text[:-1]
    return (text + ellipsis) if text else ellipsis


def draw_panel(surface, palette, rect, fill=None, border=None, title=None, title_font=None, title_color=None, radius=12, shadow=True, border_width=2):
    fill = fill or palette['panel']
    border = border or palette['border']
    title_color = title_color or palette['accent']
    if shadow:
        shadow_rect = pygame.Rect(rect.x + 4, rect.y + 5, rect.w, rect.h)
        pygame.draw.rect(surface, palette['shadow'], shadow_rect, border_radius=radius)
    pygame.draw.rect(surface, fill, rect, border_radius=radius)
    pygame.draw.rect(surface, border, rect, border_width, border_radius=radius)
    if title and title_font:
        label = title_font.render(title, True, title_color)
        surface.blit(label, (rect.x + 12, rect.y + 8))


def draw_inline_bubble(surface, palette, rect, lead, body, font, lead_color=None, body_color=None, fill=None, border=None):
    draw_panel(surface, palette, rect, fill=fill or palette['panel2'], border=border or palette['border'], radius=10, shadow=False)
    lead_color = lead_color or palette['title']
    body_color = body_color or palette['text']
    lead_surface = font.render(lead, True, lead_color)
    body_x = rect.x + 12 + lead_surface.get_width() + 8
    body_w = max(20, (rect.x + rect.w - 10) - body_x)
    baseline_y = rect.y + (rect.h - font.get_height()) // 2
    surface.blit(lead_surface, (rect.x + 12, baseline_y))
    body_surface = font.render(fit_text(font, body, body_w), True, body_color)
    surface.blit(body_surface, (body_x, baseline_y))


def _run_in_thread(target, *args, **kwargs):
    t = threading.Thread(target=target, args=args, kwargs=kwargs, daemon=True)
    t.start()
    return t


def _post_xclip_event(ok, msg):
    try:
        pygame.event.post(pygame.event.Event(XCLIP_EVENT, {"ok": bool(ok), "msg": str(msg)}))
    except Exception as exc:
        logger.exception("failed posting xclip event: %s", exc)


def check_xclip_raw():
    try:
        return bool(xclip_is_installed())
    except Exception:
        return False


def background_install_xclip(pkg_path=None):
    try:
        ok, msg = install_xclip(pkg_path)
        logger.info("xclip install result | ok=%s | msg=%s", ok, msg)
        _post_xclip_event(ok, msg)
    except Exception as exc:
        logger.exception("xclip install exception: %s", exc)
        _post_xclip_event(False, str(exc))


def background_uninstall_xclip():
    try:
        ok, msg = uninstall_xclip()
        logger.info("xclip uninstall result | ok=%s | msg=%s", ok, msg)
        _post_xclip_event(ok, msg)
    except Exception as exc:
        logger.exception("xclip uninstall exception: %s", exc)
        _post_xclip_event(False, str(exc))



    logger.warning("reboot requested")
    try:
        pygame.quit()
    except Exception:
        pass
    os.system("reboot")
    sys.exit(0)


def handle_menu_select(index):
    if index == 0:
        return launch_patcher()
    if index == 1:
        return launch_tools()
    if index == 2:
        return system_info()
    if index == 3:
        return launch_installer()
    if index == 4:
        do_reboot()
        return "Rebooting."
    if index == 5:
        pygame.quit()
        sys.exit(0)
    return "No action."


def handle_pane_select(index):
    actions = build_xclip_actions()
    if not actions:
        return "No pane actions."
    _, action = actions[index]
    if action == "state":
        return "xclip is installed." if check_xclip_raw() else "xclip is missing."
    if action == "install":
        _run_in_thread(background_install_xclip, None)
        return "Installing xclip in background..."
    if action == "uninstall":
        _run_in_thread(background_uninstall_xclip)
        return "Uninstalling xclip in background..."
    if action == "info":
        return "xclip powers clipboard-based patch/buffer workflows."
    return "Future xclip diagnostics slot."



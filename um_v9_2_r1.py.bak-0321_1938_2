        except Exception as inner_exc:
            return [f"log read failed: {inner_exc}"]

    def notation_summarize_log(path):
        if not os.path.exists(path):
            return "log missing"
        lines = 0
        warnings = 0
        errors = 0
        try:
            with open(path, "r", errors="ignore") as fh:
                for line in fh:
                    lines += 1
                    if "WARNING" in line:
                        warnings += 1
                    if "ERROR" in line:
                        errors += 1
            return f"log lines={lines} warnings={warnings} errors={errors}"
        except Exception as inner_exc:
            return f"log summary failed: {inner_exc}"

